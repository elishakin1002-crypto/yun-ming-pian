.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.intro-card,
.action-card,
.preview-card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.05);
}

.intro-card {
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
}

.desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6d7480;
  line-height: 1.65;
}

.action-card {
  padding: 24rpx;
}

.picker-btn,
.retry-btn,
.submit-btn {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.picker-btn.primary,
.submit-btn {
  background: #1f5eff;
  color: #fff;
}

.picker-btn {
  background: #f7f8fa;
  color: #344054;
}

.picker-btn + .picker-btn {
  margin-top: 14rpx;
}

.preview-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.preview-image {
  width: 100%;
  border-radius: 20rpx;
  background: #edf0f4;
}

.preview-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.retry-btn {
  flex: 1;
  background: #f7f8fa;
  color: #344054;
}

.submit-btn {
  flex: 1.3;
}

.error-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff5f5;
  border: 1rpx solid #fecaca;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #b91c1c;
  line-height: 1.5;
}

.error-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.error-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.error-btn.secondary {
  background: #ffffff;
  color: #374151;
  border: 1rpx solid #d1d5db;
}

.error-btn.primary {
  background: #1f5eff;
  color: #fff;
}
