.header {
  background-color: #4f46e5;
  color: white;
  padding: 50rpx 40rpx;
  border-radius: 24rpx;
  text-align: center;
  margin-bottom: 50rpx;
  box-shadow: 0 10rpx 30rpx rgba(79, 70, 229, 0.2);
}
.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}
.form-group {
  margin-bottom: 40rpx;
}
.label {
  font-size: 28rpx;
  color: #334155;
  margin-bottom: 20rpx;
  font-weight: bold;
}
.input {
  background-color: white;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
  width: 100%;
}
.picker {
  width: 100%;
  box-sizing: border-box;
}
.logo-upload {
  display: flex;
  align-items: center;
  gap: 30rpx;
}
.logo-preview, .logo-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  background-color: #e2e8f0;
  border: 2rpx dashed #cbd5e1;
  flex-shrink: 0;
}
.upload-btn {
  margin: 0;
  font-size: 28rpx;
  background-color: white;
  border: 2rpx solid #cbd5e1;
  color: #475569;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 76rpx;
  border-radius: 40rpx;
}
.submit-btn {
  background-color: #4f46e5;
  color: white;
  border-radius: 100rpx;
  margin-top: 80rpx;
  font-weight: bold;
  font-size: 32rpx;
  padding: 24rpx 0;
  box-shadow: 0 10rpx 30rpx rgba(79, 70, 229, 0.3);
}
.tips {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 30rpx;
  padding-bottom: 60rpx;
}