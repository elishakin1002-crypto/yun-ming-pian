<view class="page">

  <!-- 主题配色 -->
  <view class="section">
    <view class="section-title">名片主题</view>
    <view class="theme-options">
      <view
        class="theme-card {{cardStyle === 'classic' ? 'selected' : ''}}"
        bindtap="pickStyle"
        data-style="classic"
      >
        <view class="theme-swatch swatch-classic"></view>
        <text class="theme-name">经典蓝</text>
      </view>
      <view
        class="theme-card {{cardStyle === 'modern' ? 'selected' : ''}}"
        bindtap="pickStyle"
        data-style="modern"
      >
        <view class="theme-swatch swatch-modern"></view>
        <text class="theme-name">商务灰</text>
      </view>
      <view
        class="theme-card {{cardStyle === 'dark' ? 'selected' : ''}}"
        bindtap="pickStyle"
        data-style="dark"
      >
        <view class="theme-swatch swatch-dark"></view>
        <text class="theme-name">暗金</text>
      </view>
    </view>
  </view>

  <!-- 名片类型 -->
  <view class="section">
    <view class="section-title">名片类型</view>
    <view class="type-options">
      <view
        class="type-card {{cardRole === 'brand' ? 'selected' : ''}}"
        bindtap="pickRole"
        data-role="brand"
      >
        <text class="type-name">简约名片</text>
        <text class="type-desc">简洁大方，适合日常社交</text>
      </view>
      <view
        class="type-card {{cardRole === 'growth' ? 'selected' : ''}}"
        bindtap="pickRole"
        data-role="growth"
      >
        <text class="type-name">商务名片</text>
        <text class="type-desc">展示实力，促进商务合作</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section">
    <view class="section-title">更多操作</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goEdit">
        <text class="menu-label">编辑名片信息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goCreateNew">
        <text class="menu-label">新建一张名片</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>


</view>
