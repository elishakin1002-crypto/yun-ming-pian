<view class="page">
  <view class="intro-card">
    <text class="intro-title">必要设置</text>
    <text class="intro-desc">这里只做资料维护和少量商务风样式，不作为主入口。</text>
  </view>

  <view class="section">
    <view class="section-title">商务风格</view>
    <view class="theme-options">
      <view
        class="theme-card {{cardStyle === 'classic' ? 'selected' : ''}}"
        bindtap="pickStyle"
        data-style="classic"
      >
        <view class="theme-swatch swatch-classic"></view>
        <text class="theme-name">经典蓝</text>
      </view>
      <view
        class="theme-card {{cardStyle === 'modern' ? 'selected' : ''}}"
        bindtap="pickStyle"
        data-style="modern"
      >
        <view class="theme-swatch swatch-modern"></view>
        <text class="theme-name">商务灰</text>
      </view>
      <view
        class="theme-card {{cardStyle === 'dark' ? 'selected' : ''}}"
        bindtap="pickStyle"
        data-style="dark"
      >
        <view class="theme-swatch swatch-dark"></view>
        <text class="theme-name">深色商务</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">资料设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goEdit">
        <text class="menu-label">编辑名片资料</text>
        <text class="menu-desc">修改姓名、公司、职位和联系方式等基础信息</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
