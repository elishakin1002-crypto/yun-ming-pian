.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.intro-card,
.theme-card,
.menu-list {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.intro-card {
  padding: 28rpx;
  margin-bottom: 26rpx;
}

.intro-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.intro-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #6d7480;
}

.section {
  margin-bottom: 34rpx;
}

.section-title {
  font-size: 24rpx;
  color: #7a7f87;
  letter-spacing: 2rpx;
  margin: 0 0 16rpx 4rpx;
}

.theme-options {
  display: flex;
  gap: 16rpx;
}

.theme-card {
  flex: 1;
  padding: 18rpx 12rpx 14rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.theme-card.selected {
  border-color: #1f5eff;
}

.theme-swatch {
  width: 100%;
  height: 70rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.swatch-classic { background: linear-gradient(135deg, #1f5eff, #6ca3ff); }
.swatch-modern { background: linear-gradient(135deg, #475467, #667085); }
.swatch-dark {
  background: linear-gradient(135deg, #161b26, #3a4252);
  border: 1rpx solid #475467;
}

.theme-name {
  font-size: 24rpx;
  color: #344054;
  font-weight: 500;
}

.menu-list {
  overflow: hidden;
}

.menu-item {
  position: relative;
  padding: 26rpx 64rpx 26rpx 24rpx;
  border-bottom: 1rpx solid #edf0f4;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.menu-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7480;
  line-height: 1.5;
}

.menu-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #c0c4cc;
}
