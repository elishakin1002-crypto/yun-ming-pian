.page {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ---- Section ---- */
.section {
  margin-bottom: 48rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #86868b;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ---- Theme Selector ---- */
.theme-options {
  display: flex;
  gap: 20rpx;
}
.theme-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 12rpx 16rpx;
  text-align: center;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}
.theme-card.selected {
  border-color: #0066FF;
  box-shadow: 0 0 0 3rpx rgba(0, 102, 255, 0.1);
}
.theme-swatch {
  width: 100%;
  height: 72rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}
.swatch-classic {
  background: linear-gradient(135deg, #0066FF, #5AC8FA);
}
.swatch-modern {
  background: linear-gradient(135deg, #48484a, #8e8e93);
}
.swatch-dark {
  background: linear-gradient(135deg, #1c1c1e, #2c2c2e);
  border: 2rpx solid #d4a853;
}
.theme-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #3a3a3c;
}

/* ---- Type Selector ---- */
.type-options {
  display: flex;
  gap: 20rpx;
}
.type-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}
.type-card.selected {
  border-color: #0066FF;
  background: #f0f6ff;
}
.type-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 6rpx;
}
.type-desc {
  display: block;
  font-size: 22rpx;
  color: #86868b;
}

/* ---- Menu List ---- */
.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f7;
  transition: background 0.15s ease;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  background: #f9f9fb;
}
.menu-label {
  font-size: 30rpx;
  color: #1d1d1f;
}
.menu-arrow {
  font-size: 32rpx;
  color: #c7c7cc;
}
