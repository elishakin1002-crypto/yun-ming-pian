.hero {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(79,70,229,0.25);
}
.hero-logo {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  display: block;
}
.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}
.hero-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,0.05);
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 28rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4f46e5;
}

/* ---- 成就 ---- */
.achv-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.achv-item {
  width: calc(50% - 8rpx);
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  box-sizing: border-box;
}
.achv-val {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #4f46e5;
  margin-bottom: 8rpx;
}
.achv-lbl {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

/* ---- 服务卡片 ---- */
.service-list { display: flex; flex-direction: column; gap: 20rpx; }
.service-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}
.svc-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 36rpx;
  line-height: 72rpx;
  text-align: center;
}
.svc-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 8rpx;
}
.svc-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

/* ---- Why us ---- */
.why-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.why-check { font-size: 28rpx; flex-shrink: 0; line-height: 1.6; }
.why-text  { font-size: 28rpx; color: #334155; line-height: 1.6; }

/* ---- CTA ---- */
.cta-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.btn-consult {
  background: #4f46e5;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  height: 96rpx;
  line-height: 96rpx;
  box-shadow: 0 8rpx 24rpx rgba(79,70,229,0.28);
  margin: 0;
}
.btn-register {
  background: #fff;
  color: #4f46e5;
  border: 2rpx solid #4f46e5;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
}

.tab-placeholder { height: 130rpx; }
