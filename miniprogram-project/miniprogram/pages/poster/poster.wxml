<view class="container">
  <!-- Canvas 用于绘制（不可见，放在屏幕外绘制后导出图片） -->
  <canvas
    type="2d"
    id="posterCanvas"
    class="offscreen-canvas"
  ></canvas>

  <!-- 加载中 -->
  <view wx:if="{{isDrawing}}" class="center-tip">🎨 海报生成中...</view>

  <!-- 预览 + 操作 -->
  <view wx:elif="{{posterPath}}" class="preview-wrap">
    <image src="{{posterPath}}" class="poster-img" mode="widthFix" show-menu-by-longpress="true" />
    <view class="hint">长按图片也可以直接保存或转发</view>
    <button class="btn-save" bindtap="saveToAlbum">保存到相册</button>
    <button class="btn-back" bindtap="goBack">返回名片</button>
  </view>

  <view wx:else class="center-tip">海报生成失败，请返回重试</view>
</view>
