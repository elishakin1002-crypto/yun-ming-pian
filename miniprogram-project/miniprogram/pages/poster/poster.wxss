.offscreen-canvas {
  width: 750rpx;
  height: 1200rpx;
  position: fixed;
  left: -9999rpx;
}

.container {
  min-height: 100vh;
  background: #f5f5f7;
}

.center-tip {
  text-align: center;
  padding-top: 200rpx;
  font-size: 28rpx;
  color: #86868b;
}

.preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 40rpx;
}
.poster-img {
  width: 100%;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(15, 23, 42, 0.12);
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}
.hint {
  font-size: 22rpx;
  color: #86868b;
  margin-bottom: 36rpx;
}

.btn-save {
  width: 100%;
  background: #0066FF;
  color: #fff;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0 0 20rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(0, 102, 255, 0.2);
}
.btn-save:active {
  transform: scale(0.98);
}
.btn-save::after { border: none; }

.btn-back {
  width: 100%;
  background: #ffffff;
  color: #1d1d1f;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.btn-back:active {
  background: #f5f5f7;
}
.btn-back::after { border: none; }
