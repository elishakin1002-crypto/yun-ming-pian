.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 28rpx 24rpx 0;
  box-sizing: border-box;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 260rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1f5eff;
  opacity: 0.28;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.28; transform: scale(0.82); }
  50% { opacity: 1; transform: scale(1); }
}

.loading-text {
  margin-top: 22rpx;
  font-size: 28rpx;
  color: #7a7f87;
}

.empty-state {
  padding-top: 180rpx;
}

.empty-panel,
.summary-card,
.client-card,
.note-sheet {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.05);
}

.empty-panel {
  padding: 36rpx 30rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
}

.empty-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #6d7480;
}

.empty-action {
  margin-top: 26rpx;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: #1f5eff;
  color: #fff;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-action-light {
  background: #ffffff;
  color: #1f5eff;
  border: 1rpx solid #b2ccff;
}

.summary-card {
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.summary-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.summary-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6d7480;
  line-height: 1.55;
}

.client-card {
  overflow: hidden;
  margin-bottom: 18rpx;
}

.client-main {
  padding: 28rpx;
}

.client-head {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.client-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1f5eff, #6ca3ff);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.client-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.client-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.client-title {
  font-size: 22rpx;
  color: #667085;
  background: #f2f4f7;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.client-company {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #475467;
  line-height: 1.5;
}

.client-arrow {
  font-size: 34rpx;
  color: #c0c4cc;
}

.info-grid {
  display: flex;
  gap: 22rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf0f4;
}

.info-item {
  flex: 1;
  min-width: 0;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #98a2b3;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  word-break: break-all;
}

.note-block {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8f9fb;
}

.note-label {
  display: block;
  font-size: 22rpx;
  color: #98a2b3;
  margin-bottom: 8rpx;
}

.note-value {
  display: block;
  font-size: 25rpx;
  line-height: 1.65;
  color: #475467;
}

.time-row {
  margin-top: 18rpx;
}

.time-text {
  font-size: 22rpx;
  color: #98a2b3;
}

.action-row {
  display: flex;
  border-top: 1rpx solid #edf0f4;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #1f5eff;
  border-right: 1rpx solid #edf0f4;
}

.action-btn:last-child {
  border-right: none;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.36);
  z-index: 100;
}

.note-sheet {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 0 28rpx 24rpx;
  transform: translateY(120%);
  transition: transform 0.24s ease;
  z-index: 101;
}

.note-sheet.show {
  transform: translateY(0);
}

.sheet-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #edf0f4;
}

.sheet-cancel,
.sheet-save {
  font-size: 28rpx;
}

.sheet-cancel {
  color: #667085;
}

.sheet-save {
  color: #1f5eff;
  font-weight: 600;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.note-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx 0 0;
  font-size: 28rpx;
  color: #1f2329;
  line-height: 1.65;
  box-sizing: border-box;
}

.create-guide-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(130rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(17, 24, 39, 0.94);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.18);
}

.guide-text {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.45;
}

.guide-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: #1f5eff;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
}

.tab-placeholder {
  height: 130rpx;
}
