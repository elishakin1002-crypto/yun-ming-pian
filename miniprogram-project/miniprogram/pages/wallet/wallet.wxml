<view class="page">
  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="loading-dot"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Empty State -->
  <view wx:elif="{{cards.length === 0}}" class="empty-state">
    <view class="empty-illustration">
      <view class="empty-icon-circle">
        <text class="empty-icon-text">+</text>
      </view>
    </view>
    <text class="empty-title">客户名片还没有</text>
    <text class="empty-desc">浏览客户名片时，点击"收藏名片"或互换联系方式后自动存入</text>
    <view wx:if="{{!hasOwnCard}}" class="empty-action" bindtap="goCreateCard">
      <text>先创建自己的名片</text>
    </view>
  </view>

  <!-- Card List -->
  <view wx:else class="wallet-list">
    <view class="wallet-header">
      <text class="wallet-count">共 {{cards.length}} 位联系人</text>
    </view>

    <view
      wx:for="{{cards}}"
      wx:key="_id"
      class="wallet-card"
    >
      <!-- Card Info -->
      <view class="card-main" bindtap="viewCard" data-cardid="{{item.cardId}}">
        <image
          wx:if="{{item.cardSnapshot.logoUrl}}"
          src="{{item.cardSnapshot.logoUrl}}"
          class="card-avatar"
          mode="aspectFill"
        />
        <view wx:else class="card-avatar-placeholder">
          <text>{{item.cardSnapshot.contactName ? item.cardSnapshot.contactName[0] : '?'}}</text>
        </view>
        <view class="card-info">
          <view class="card-name-row">
            <text class="card-name">{{item.cardSnapshot.contactName}}</text>
            <text wx:if="{{item.cardSnapshot.title}}" class="card-title-badge">{{item.cardSnapshot.title}}</text>
          </view>
          <text class="card-company">{{item.cardSnapshot.companyName}}</text>
          <text class="card-phone">{{item.cardSnapshot.phone}}</text>
          <text wx:if="{{item.cardSnapshot.industry}}" class="card-industry">{{item.cardSnapshot.industry}}</text>
        </view>
        <text class="card-arrow">›</text>
      </view>

      <!-- Note -->
      <view wx:if="{{item.note}}" class="card-note">
        <text class="note-label">备注</text>
        <text class="note-content">{{item.note}}</text>
      </view>

      <!-- Quick Actions -->
      <view class="card-actions">
        <view class="action-chip" bindtap="callPhone" data-phone="{{item.cardSnapshot.phone}}">
          <text class="chip-text">拨号</text>
        </view>
        <view class="action-chip" bindtap="copyWechat" data-wechat="{{item.cardSnapshot.wechat}}">
          <text class="chip-text">复制微信</text>
        </view>
        <view class="action-chip" bindtap="showNoteEditor" data-id="{{item._id}}" data-note="{{item.note}}">
          <text class="chip-text">{{item.note ? '编辑备注' : '添加备注'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 注册引导条：仅对还没有名片的用户显示 -->
  <view wx:if="{{!hasOwnCard && !isLoading}}" class="create-guide-bar" bindtap="goCreateCard">
    <text class="guide-text">你也想拥有一张？30秒即可创建</text>
    <text class="guide-btn">立即创建 ›</text>
  </view>

  <view class="tab-placeholder"></view>
</view>

<!-- Note Editor Modal -->
<view wx:if="{{editingNote}}" class="mask" bindtap="cancelNote"></view>
<view class="note-sheet {{editingNote ? 'show' : ''}}">
  <view class="sheet-bar">
    <text class="sheet-cancel" bindtap="cancelNote">取消</text>
    <text class="sheet-title">编辑备注</text>
    <text class="sheet-save" bindtap="saveNote">保存</text>
  </view>
  <textarea
    class="note-textarea"
    placeholder="记录你与对方的交流内容、跟进事项等..."
    value="{{noteText}}"
    bindinput="onNoteInput"
    maxlength="500"
    auto-height
    focus="{{!!editingNote}}"
  />
</view>
