<view class="page">
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="loading-dot"></view>
    <text class="loading-text">客户资料加载中...</text>
  </view>

  <view wx:elif="{{cards.length === 0}}" class="empty-state">
    <view class="empty-panel">
      <text class="empty-title">客户资料还没有沉淀下来</text>
      <text class="empty-desc">你发出名片后，对方保存名片或交换联系方式，客户资料会自动收录在这里。</text>
    </view>
    <view wx:if="{{!hasOwnCard}}" class="empty-action" bindtap="goCreateCard">创建名片并开始沉淀</view>
    <view wx:else class="empty-action empty-action-light" bindtap="goShareCard">去发名片收集客户资料</view>
  </view>

  <view wx:else class="content">
    <view class="summary-card">
      <text class="summary-title">客户资料</text>
      <text class="summary-desc">已沉淀 {{cards.length}} 位客户联系人，按最新收录时间排序。</text>
    </view>

    <view
      wx:for="{{cards}}"
      wx:key="_id"
      class="client-card"
    >
      <view class="client-main" bindtap="viewCard" data-cardid="{{item.cardId}}">
        <view class="client-head">
          <view class="client-avatar">
            <text>{{item.cardSnapshot.contactName ? item.cardSnapshot.contactName[0] : '?'}}</text>
          </view>
          <view class="client-info">
            <view class="name-row">
              <text class="client-name">{{item.cardSnapshot.contactName || '未填写姓名'}}</text>
              <text wx:if="{{item.cardSnapshot.title}}" class="client-title">{{item.cardSnapshot.title}}</text>
            </view>
            <text class="client-company">{{item.cardSnapshot.companyName || '未填写公司'}}</text>
          </view>
          <text class="client-arrow">{{item.cardId ? '›' : ''}}</text>
        </view>

        <view class="info-grid">
          <view class="info-item">
            <text class="info-label">电话</text>
            <text class="info-value">{{item.cardSnapshot.phone || '未填写'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">微信</text>
            <text class="info-value">{{item.cardSnapshot.wechat || '未填写'}}</text>
          </view>
        </view>

        <view class="note-block">
          <text class="note-label">备注</text>
          <text class="note-value">{{item.note || '还没有备注，建议补充来源、需求或跟进情况。'}}</text>
        </view>

        <view class="time-row">
          <text class="time-text">收录时间 {{item.savedTimeLabel}}</text>
        </view>
      </view>

      <view class="action-row">
        <view class="action-btn" bindtap="callPhone" data-phone="{{item.cardSnapshot.phone}}">拨号</view>
        <view class="action-btn" bindtap="copyWechat" data-wechat="{{item.cardSnapshot.wechat}}">复制微信</view>
        <view class="action-btn" bindtap="showNoteEditor" data-id="{{item._id}}" data-note="{{item.note}}">编辑备注</view>
      </view>
    </view>
  </view>

  <view wx:if="{{!hasOwnCard && !isLoading}}" class="create-guide-bar" bindtap="goCreateCard">
    <text class="guide-text">创建自己的名片后，交换联系方式会更顺。</text>
    <text class="guide-btn">去创建</text>
  </view>

  <view class="tab-placeholder"></view>
</view>

<view wx:if="{{editingNote}}" class="mask" bindtap="cancelNote"></view>
<view class="note-sheet {{editingNote ? 'show' : ''}}">
  <view class="sheet-bar">
    <text class="sheet-cancel" bindtap="cancelNote">取消</text>
    <text class="sheet-title">编辑备注</text>
    <text class="sheet-save" bindtap="saveNote">保存</text>
  </view>
  <textarea
    class="note-textarea"
    placeholder="记录客户需求、来源、合作进度或下次跟进时间"
    value="{{noteText}}"
    bindinput="onNoteInput"
    maxlength="500"
    auto-height
    focus="{{!!editingNote}}"
  />
</view>
