.page {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ---- Loading ---- */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 280rpx;
}
.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #0066FF;
  opacity: 0.3;
  animation: pulse 1.2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}
.loading-text {
  font-size: 28rpx;
  color: #86868b;
  margin-top: 24rpx;
}

/* ---- Empty State ---- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
}
.empty-visual {
  margin-bottom: 48rpx;
}
.empty-card-mock {
  width: 360rpx;
  height: 220rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}
.mock-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e5e5ea;
  flex-shrink: 0;
}
.mock-lines {
  flex: 1;
  padding-top: 8rpx;
}
.mock-line {
  height: 14rpx;
  background: #e5e5ea;
  border-radius: 7rpx;
  margin-bottom: 14rpx;
}
.w60 { width: 60%; }
.w40 { width: 40%; }
.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 28rpx;
  color: #86868b;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.5;
}
.btn-create-card {
  background: #0066FF;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
  max-width: 480rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 102, 255, 0.2);
}
.btn-create-card::after { border: none; }

/* ---- Multi-card Switcher ---- */
.card-switcher {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 4rpx 0;
}
.switcher-chip {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 400;
  color: #aeaeb2;
  background: rgba(255,255,255,0.7);
  margin-right: 10rpx;
  border: 1rpx solid #e5e5ea;
  transition: all 0.25s ease;
}
.switcher-chip.active {
  background: #1d1d1f;
  color: #fff;
  border-color: #1d1d1f;
  font-weight: 500;
}
.add-chip {
  color: #c7c7cc;
  border: 1rpx solid #e5e5ea;
  background: rgba(255,255,255,0.7);
  box-shadow: none;
  font-size: 24rpx;
  font-weight: 500;
  min-width: 48rpx;
  text-align: center;
}

/* ---- Card Preview ---- */
.card-preview {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}
.card-preview:active {
  transform: scale(0.985);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}
.preview-theme-line {
  height: 10rpx;
}
.preview-theme-line.theme-classic { background: linear-gradient(90deg, #0055cc, #0066FF); }
.preview-theme-line.theme-modern { background: linear-gradient(90deg, #3a3a3c, #636366); }
.preview-theme-line.theme-dark { background: linear-gradient(90deg, #b8860b, #d4a853); }

.preview-body {
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx 28rpx;
  gap: 28rpx;
}
.preview-avatar {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f5;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.1);
}
.preview-avatar-default {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0066FF, #5AC8FA);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
  font-size: 56rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 16rpx rgba(0, 102, 255, 0.15);
}
.preview-info {
  flex: 1;
  min-width: 0;
}
.preview-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1d1d1f;
  line-height: 1.2;
  letter-spacing: 2rpx;
}
.preview-title {
  display: block;
  font-size: 24rpx;
  color: #aeaeb2;
  margin-top: 6rpx;
}
.preview-company {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3a3a3c;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}
.preview-industry {
  display: block;
  font-size: 22rpx;
  color: #c7c7cc;
  margin-top: 4rpx;
}

.preview-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 30rpx;
  border-top: 1rpx solid #f2f2f7;
  margin: 0 36rpx;
}
.preview-phone {
  font-size: 28rpx;
  color: #3a3a3c;
  letter-spacing: 2rpx;
  font-weight: 500;
}
.preview-tap-hint {
  font-size: 22rpx;
  color: #d1d1d6;
}

/* ---- Data Hint (lightweight feedback) ---- */
.data-hint {
  text-align: center;
  font-size: 24rpx;
  color: #aeaeb2;
  padding: 8rpx 0 20rpx;
}

/* ---- Dual Action Buttons ---- */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.btn-share {
  flex: 2;
  background: #0055cc;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 85, 204, 0.22);
  letter-spacing: 2rpx;
}
.btn-share::after { border: none; }
.btn-share:active {
  transform: scale(0.98);
  background: #0044aa;
}
.btn-edit {
  flex: 1;
  background: #fff;
  color: #3a3a3c;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #e5e5ea;
}
.btn-edit:active {
  background: #f5f5f7;
}

/* ---- Function Entries ---- */
.entries {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
.entry-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f5f5f7;
  position: relative;
}
.entry-item:last-child {
  border-bottom: none;
}
.entry-item:active {
  background: #f9f9fb;
}
.entry-icon-box {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* CSS icons */
.icon-poster {
  width: 28rpx;
  height: 34rpx;
  border: 3rpx solid #86868b;
  border-radius: 4rpx;
  position: relative;
}
.icon-poster::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 10rpx solid #86868b;
}

.icon-leads {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #86868b;
  border-radius: 50%;
  position: relative;
}
.icon-leads::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 4rpx;
  height: 4rpx;
  background: #86868b;
  border-radius: 50%;
  box-shadow: -8rpx 0 0 #86868b, 8rpx 0 0 #86868b;
}

.icon-settings {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid #86868b;
  border-radius: 50%;
  position: relative;
}
.icon-settings::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid #86868b;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.icon-scan {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #86868b;
  border-radius: 3rpx;
  position: relative;
}
.icon-scan::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 2rpx;
  right: 2rpx;
  height: 2rpx;
  background: #86868b;
  transform: translateY(-50%);
}
.icon-scan::after {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 50%;
  bottom: 2rpx;
  width: 2rpx;
  background: #86868b;
  transform: translateX(-50%);
}

.entry-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1d1d1f;
}
.entry-badge {
  background: #FF3B30;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 100rpx;
  text-align: center;
  padding: 0 8rpx;
  font-weight: 600;
  margin-right: 8rpx;
}
.entry-arrow {
  font-size: 32rpx;
  color: #c7c7cc;
  flex-shrink: 0;
}

.tab-placeholder {
  height: 130rpx;
}
