.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 28rpx 24rpx 0;
  box-sizing: border-box;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 280rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1f5eff;
  opacity: 0.28;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.28; transform: scale(0.82); }
  50% { opacity: 1; transform: scale(1); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #7a7f87;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 168rpx 36rpx 0;
}

.empty-card-mock {
  width: 100%;
  max-width: 560rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 48rpx;
}

.mock-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin: 26rpx 0;
}

.mock-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  background: #e8eaee;
  flex-shrink: 0;
}

.mock-lines {
  flex: 1;
}

.mock-line {
  height: 16rpx;
  border-radius: 8rpx;
  background: #e8eaee;
  margin-bottom: 16rpx;
}

.mock-line.strong {
  width: 36%;
  height: 18rpx;
}

.mock-contact {
  padding-top: 8rpx;
  border-top: 1rpx solid #eef0f3;
}

.w40 { width: 40%; }
.w50 { width: 50%; }
.w60 { width: 60%; }
.w80 { width: 80%; }

.empty-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2329;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  line-height: 1.65;
  color: #6d7480;
  text-align: center;
  margin-bottom: 44rpx;
}

.btn-create-card {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #1f5eff;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  box-shadow: 0 10rpx 24rpx rgba(31, 94, 255, 0.18);
}

.btn-create-card::after {
  border: none;
}

.content {
  padding-bottom: 16rpx;
}

.top-create-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 4rpx 0 18rpx;
  padding: 26rpx 28rpx;
  background: linear-gradient(135deg, #1f5eff, #4d8dff);
  border-radius: 28rpx;
  color: #fff;
  box-shadow: 0 12rpx 30rpx rgba(31, 94, 255, 0.2);
}

.top-create-copy {
  flex: 1;
  min-width: 0;
}

.top-create-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.top-create-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.top-create-arrow {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  font-size: 38rpx;
  font-weight: 600;
}

.card-switcher {
  white-space: nowrap;
  margin-bottom: 14rpx;
}

.switcher-chip {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #6d7480;
  font-size: 22rpx;
  border: 1rpx solid #e4e7ec;
}

.switcher-chip.active {
  background: #1f2329;
  color: #fff;
  border-color: #1f2329;
}

.add-chip {
  color: #7a7f87;
}

.section-title {
  margin: 18rpx 0 18rpx;
  padding-left: 4rpx;
  font-size: 24rpx;
  color: #7a7f87;
  letter-spacing: 2rpx;
}

.business-card {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.06);
}

.card-accent {
  height: 10rpx;
}

.theme-classic { background: linear-gradient(90deg, #1f5eff, #4d8dff); }
.theme-modern { background: linear-gradient(90deg, #475467, #667085); }
.theme-dark { background: linear-gradient(90deg, #161b26, #3a4252); }

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 8rpx;
}

.card-tag {
  font-size: 24rpx;
  color: #7a7f87;
}

.card-preview-link {
  font-size: 24rpx;
  color: #1f5eff;
}

.identity-block {
  display: flex;
  gap: 24rpx;
  padding: 18rpx 28rpx 28rpx;
}

.identity-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #eef0f3;
  flex-shrink: 0;
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1f5eff, #6ca3ff);
  color: #fff;
  font-size: 46rpx;
  font-weight: 700;
}

.identity-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.identity-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.2;
}

.identity-title {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #667085;
}

.identity-company {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #344054;
  line-height: 1.35;
}

.contact-board {
  margin: 0 28rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid #edf0f4;
  display: flex;
  gap: 28rpx;
}

.contact-item {
  flex: 1;
  min-width: 0;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #98a2b3;
  margin-bottom: 8rpx;
}

.contact-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  word-break: break-all;
}

.card-meta {
  padding: 0 28rpx 26rpx;
  font-size: 22rpx;
  color: #98a2b3;
}

.action-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 22rpx 0 30rpx;
}

.btn-share {
  width: 100%;
  height: 98rpx;
  line-height: 98rpx;
  background: #1f5eff;
  color: #fff;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  box-shadow: 0 12rpx 28rpx rgba(31, 94, 255, 0.2);
}

.btn-share::after {
  border: none;
}

.edit-link {
  margin-top: 16rpx;
  padding: 4rpx 12rpx;
  font-size: 26rpx;
  color: #667085;
  border-bottom: 1rpx solid #d0d5dd;
}

.entry-list {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.04);
}

.entry-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 28rpx;
  border-bottom: 1rpx solid #edf0f4;
}

.entry-item:last-child {
  border-bottom: none;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.entry-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.entry-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 8rpx;
}

.entry-desc {
  display: block;
  font-size: 23rpx;
  line-height: 1.5;
  color: #6d7480;
}

.entry-badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #f04438;
  color: #fff;
  border-radius: 999rpx;
  font-size: 20rpx;
  text-align: center;
  font-weight: 600;
}

.entry-arrow {
  font-size: 34rpx;
  color: #c0c4cc;
}

.tab-placeholder {
  height: 130rpx;
}
