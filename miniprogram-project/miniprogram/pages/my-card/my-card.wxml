<view class="page">
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="loading-dot"></view>
    <text class="loading-text">名片加载中...</text>
  </view>

  <view wx:elif="{{!card}}" class="empty-state">
    <view class="empty-card-mock">
      <view class="mock-line strong"></view>
      <view class="mock-row">
        <view class="mock-avatar"></view>
        <view class="mock-lines">
          <view class="mock-line w50"></view>
          <view class="mock-line w80"></view>
        </view>
      </view>
      <view class="mock-contact">
        <view class="mock-line w60"></view>
        <view class="mock-line w40"></view>
      </view>
    </view>
    <text class="empty-title">先创建一张商务名片</text>
    <text class="empty-desc">建好后就能直接发给客户，收集联系方式并沉淀客户资料。</text>
    <button class="btn-create-card" bindtap="goRegister">立即创建名片</button>
  </view>

  <view wx:else class="content">
    <view class="top-create-entry" bindtap="goCreateNew">
      <view class="top-create-copy">
        <text class="top-create-title">再建一张名片</text>
        <text class="top-create-desc">已有名片也可以继续新建，服务不同业务场景或不同身份。</text>
      </view>
      <text class="top-create-arrow">+</text>
    </view>

    <scroll-view wx:if="{{cards.length > 1}}" scroll-x class="card-switcher">
      <view
        wx:for="{{cards}}"
        wx:key="_id"
        class="switcher-chip {{activeCardIndex === index ? 'active' : ''}}"
        bindtap="switchCard"
        data-index="{{index}}"
      >
        {{item.cardName || item.contactName || ('名片' + (index + 1))}}
      </view>
      <view class="switcher-chip add-chip" bindtap="goCreateNew">+ 新建</view>
    </scroll-view>

    <view class="section-title">当前发出的名片</view>

    <view class="business-card" bindtap="previewCard">
      <view class="card-accent theme-{{card.cardStyle || 'classic'}}"></view>
      <view class="card-head">
        <text class="card-tag">{{card.cardName || '我的名片'}}</text>
        <text class="card-preview-link">查看详情</text>
      </view>

      <view class="identity-block">
        <image wx:if="{{card.logoUrl}}" src="{{card.logoUrl}}" class="identity-avatar" mode="aspectFill" />
        <image wx:elif="{{card.companyLogoUrl}}" src="{{card.companyLogoUrl}}" class="identity-avatar" mode="aspectFill" />
        <view wx:else class="identity-avatar default-avatar">
          <text>{{card.contactName ? card.contactName[0] : '?'}}</text>
        </view>
        <view class="identity-main">
          <text class="identity-name">{{card.contactName}}</text>
          <text wx:if="{{card.title}}" class="identity-title">{{card.title}}</text>
          <text class="identity-company">{{card.companyName || '未填写公司'}}</text>
        </view>
      </view>

      <view class="contact-board">
        <view class="contact-item">
          <text class="contact-label">电话</text>
          <text class="contact-value">{{card.phone || '未填写'}}</text>
        </view>
        <view class="contact-item">
          <text class="contact-label">微信</text>
          <text class="contact-value">{{card.wechat || '未填写'}}</text>
        </view>
      </view>

      <view wx:if="{{card.views > 0 || card.saves > 0}}" class="card-meta">
        <text wx:if="{{card.views > 0}}">{{card.views}} 次查看</text>
        <text wx:if="{{card.views > 0 && card.saves > 0}}"> · </text>
        <text wx:if="{{card.saves > 0}}">{{card.saves}} 次保存</text>
      </view>
    </view>

    <view class="action-panel">
      <button class="btn-share" open-type="share">发名片</button>
      <view class="edit-link" bindtap="goEdit">编辑资料</view>
    </view>

    <view class="section-title">次级入口</view>

    <view class="entry-list">
      <view class="entry-item" bindtap="goWallet">
        <view class="entry-main">
          <text class="entry-title">客户名片</text>
          <text class="entry-desc">查看已保存的客户资料，继续补备注和联系。</text>
        </view>
        <text class="entry-arrow">›</text>
      </view>
      <view class="entry-item" bindtap="goLeads">
        <view class="entry-main">
          <view class="entry-title-row">
            <text class="entry-title">我的线索</text>
            <view wx:if="{{newLeadCount > 0}}" class="entry-badge">{{newLeadCount}}</view>
          </view>
          <text class="entry-desc">查看对方主动交换或留下的联系方式。</text>
        </view>
        <text class="entry-arrow">›</text>
      </view>
      <view class="entry-item" bindtap="goScanCard">
        <view class="entry-main">
          <text class="entry-title">纸质名片识别</text>
          <text class="entry-desc">拍照识别纸质名片，确认后沉淀到客户资料。</text>
        </view>
        <text class="entry-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="tab-placeholder"></view>
  <canvas id="shareCanvas" type="2d" style="position:fixed;left:-9999px;width:500px;height:400px;"></canvas>
</view>
