.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #f5f5f7;
  box-sizing: border-box;
}

.center-tip {
  text-align: center;
  color: #86868b;
  font-size: 28rpx;
  padding-top: 200rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  text-align: center;
}
.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  color: #c7c7cc;
}
.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #86868b;
  line-height: 1.6;
  margin-bottom: 48rpx;
  padding: 0 40rpx;
}
.btn-primary {
  background: #0066FF;
  color: #fff;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 60rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 102, 255, 0.2);
}
.btn-primary::after { border: none; }
.btn-primary:active {
  transform: scale(0.98);
}

/* Header */
.leads-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.header-tip {
  font-size: 26rpx;
  color: #86868b;
}
.btn-export {
  margin: 0;
  background: #e8f2ff;
  color: #0066FF;
  border: none;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 28rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
}
.btn-export:active {
  background: #d6e8ff;
}
.btn-export::after { border: none; }

/* Lead Card */
.lead-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border-left: 6rpx solid transparent;
}
.lead-card.unread {
  border-left-color: #0066FF;
}

.lead-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.lead-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e8f2ff;
  color: #0066FF;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.lead-meta { flex: 1; min-width: 0; }
.lead-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}
.lead-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.new-badge {
  background: #FF3B30;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 100rpx;
  font-weight: 500;
}
.lead-company {
  font-size: 24rpx;
  color: #86868b;
}
.lead-time {
  font-size: 22rpx;
  color: #aeaeb2;
  flex-shrink: 0;
}

.lead-message {
  background: #f5f5f7;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #3a3a3c;
  margin-bottom: 16rpx;
  line-height: 1.5;
  font-style: italic;
}

.lead-actions {
  display: flex;
  gap: 12rpx;
}
.btn-act {
  flex: 1;
  margin: 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: normal;
}
.btn-act::after { border: none; }
.btn-act.call {
  background: #f0fdf4;
  color: #34C759;
}
.btn-act.call:active {
  background: #dcfce7;
}
.btn-act.wechat {
  background: #e8f2ff;
  color: #0066FF;
}
.btn-act.wechat:active {
  background: #d6e8ff;
}
