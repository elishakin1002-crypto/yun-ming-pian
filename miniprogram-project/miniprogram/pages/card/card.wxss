.page {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 24rpx;
  padding-bottom: 260rpx;
  box-sizing: border-box;
}

/* ---- Loading ---- */
.loading-state {
  display: flex;
  justify-content: center;
  padding-top: 300rpx;
}
.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #0066FF;
  opacity: 0.3;
  animation: pulse 1.2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

.empty-state {
  text-align: center;
  padding-top: 300rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #86868b;
}

/* ============================================
   Card
   ============================================ */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.profile-header {
  padding: 40rpx 36rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f5;
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}
.profile-avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}
.profile-details {
  flex: 1;
  min-width: 0;
}
.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}
.profile-title {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 6rpx;
}
.profile-company {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 1rpx;
}

/* Bio — 弱化，辅助内容 */
.bio-section {
  padding: 0 36rpx 20rpx;
}
.bio-text {
  font-size: 26rpx;
  color: #6e6e73;
  line-height: 1.65;
  display: block;
  padding: 18rpx 20rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 12rpx;
}

/* Services — 弱化 */
.services-section {
  padding: 0 36rpx 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.service-chip {
  font-size: 22rpx;
  font-weight: 400;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  opacity: 0.85;
}

/* Slogan — 弱化 */
.slogan {
  margin: 0 36rpx 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 400;
  text-align: center;
  opacity: 0.75;
}

/* Contact List */
.contact-list {
  padding: 8rpx 36rpx 36rpx;
}
.contact-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f2f2f7;
}
.contact-item:last-child {
  border-bottom: none;
}
.contact-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f2f2f7;
  display: flex;
  align-items: center;
  justify-content: center;
}
.phone-icon { background: #eaf3ff; }
.wechat-icon { background: #eaf3ff; }
.industry-icon { background: #f5f0e8; }

.contact-detail {
  flex: 1;
}
.contact-label {
  display: block;
  font-size: 22rpx;
  color: #aeaeb2;
  margin-bottom: 4rpx;
}
.contact-value {
  display: block;
  font-size: 32rpx;
  color: #1d1d1f;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ============================================
   Theme: Classic Blue
   ============================================ */
.theme-classic .profile-header {
  background: linear-gradient(135deg, #0066FF, #5AC8FA);
}
.theme-classic .profile-name { color: #fff; }
.theme-classic .profile-title { color: rgba(255,255,255,0.8); }
.theme-classic .profile-company { color: #fff; font-weight: 600; }
.theme-classic .profile-avatar { border-color: rgba(255,255,255,0.5); }
.theme-classic .profile-avatar-default { background: rgba(255,255,255,0.2); }
.theme-classic .service-chip {
  background: #e8f2ff;
  color: #0066FF;
}
.theme-classic .slogan {
  background: #e8f2ff;
  color: #0055d4;
}

/* ============================================
   Theme: Modern Gray
   ============================================ */
.theme-modern {
  background: #f8f8fa;
  border: 1rpx solid #e5e5ea;
}
.theme-modern .profile-header {
  background: linear-gradient(135deg, #48484a, #636366);
}
.theme-modern .profile-name { color: #fff; }
.theme-modern .profile-title { color: rgba(255,255,255,0.75); }
.theme-modern .profile-company { color: #fff; font-weight: 600; }
.theme-modern .profile-avatar-default { background: rgba(255,255,255,0.15); }
.theme-modern .service-chip {
  background: #e5e5ea;
  color: #3a3a3c;
}
.theme-modern .slogan {
  background: #e5e5ea;
  color: #48484a;
}

/* ============================================
   Theme: Dark Gold
   ============================================ */
.theme-dark {
  background: #1c1c1e;
}
.theme-dark .profile-header {
  background: linear-gradient(135deg, #1c1c1e, #2c2c2e);
  border-bottom: 3rpx solid #d4a853;
}
.theme-dark .profile-name { color: #d4a853; }
.theme-dark .profile-title { color: #aeaeb2; }
.theme-dark .profile-company { color: #e5e5ea; font-weight: 600; }
.theme-dark .profile-avatar { border-color: #d4a853; }
.theme-dark .profile-avatar-default { background: #2c2c2e; color: #d4a853; }
.theme-dark .bio-text { background: #2c2c2e; color: #e5e5ea; }
.theme-dark .service-chip { background: #2c2c2e; color: #d4a853; }
.theme-dark .slogan { background: #2c2c2e; color: #d4a853; border: 1rpx solid rgba(212,168,83,0.3); }
.theme-dark .contact-item { border-bottom-color: #2c2c2e; }
.theme-dark .contact-label { color: #636366; }
.theme-dark .contact-value { color: #e5e5ea; }

/* ============================================
   Action Bar — Reference style: primary + icon row
   ============================================ */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.action-row-primary {
  display: flex;
  gap: 16rpx;
}

/* 主人模式：分享名片按钮 */
.owner-share-btn {
  flex: 1;
  background: #0066FF;
  color: #fff;
  border-radius: 24rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  box-shadow: 0 4rpx 16rpx rgba(0, 102, 255, 0.2);
}
.owner-share-btn::after { border: none; }
.owner-share-btn:active { transform: scale(0.98); }

/* 主人模式：编辑名片按钮 */
.action-btn-owner-edit {
  flex: 1;
  background: #fff;
  color: #1d1d1f;
  border-radius: 24rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.action-btn-owner-edit:active { background: #f5f5f7; }
.action-btn-primary {
  flex: 1;
  background: #0066FF;
  color: #fff;
  border-radius: 24rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 102, 255, 0.2);
}
.action-btn-primary:active {
  transform: scale(0.98);
}
.action-row-secondary {
  display: flex;
  gap: 12rpx;
}
.action-btn-secondary {
  flex: 1;
  height: 88rpx;
  background: #f5f5f7;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  min-width: 0;
  transition: background 0.15s ease;
}
.action-btn-secondary:active {
  background: #e8e8ed;
}
.action-btn-secondary::after { border: none; }
.btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #3a3a3c;
}

/* ============================================
   Exchange Card Sheet
   ============================================ */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}
.lead-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
}
.lead-sheet.show {
  transform: translateY(0);
}
.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
}
.sheet-close {
  font-size: 36rpx;
  color: #aeaeb2;
  padding: 10rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sheet-desc {
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 32rpx;
  display: block;
  line-height: 1.5;
}

/* Form fields (kept for backwards compat) */
.form-field {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  font-size: 24rpx;
  color: #86868b;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.form-input {
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  font-size: 30rpx;
  color: #1d1d1f;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  transition: border-color 0.2s ease;
}
.form-input:focus {
  border-color: #0066FF;
  background: #fff;
}
.form-textarea {
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  font-size: 30rpx;
  color: #1d1d1f;
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx;
  border: 1rpx solid transparent;
}

.btn-submit {
  background: #0066FF;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-top: 16rpx;
  border: none;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 102, 255, 0.2);
}
.btn-submit::after { border: none; }
.btn-submit.disabled { opacity: 0.5; }
.sheet-tip {
  text-align: center;
  font-size: 22rpx;
  color: #aeaeb2;
  margin-top: 20rpx;
  display: block;
}

/* ============================================
   Exchange Card List
   ============================================ */
.exchange-card-list {
  margin-top: 16rpx;
}
.exchange-card-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  background: #f9f9fb;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  transition: background 0.15s ease;
}
.exchange-card-item:active {
  background: #f0f0f5;
}
.exchange-card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0066FF, #5AC8FA);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
.exchange-card-info {
  flex: 1;
  min-width: 0;
}
.exchange-card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 4rpx;
}
.exchange-card-detail {
  display: block;
  font-size: 24rpx;
  color: #86868b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.exchange-card-action {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #0066FF;
  padding: 12rpx 28rpx;
  background: #e8f2ff;
  border-radius: 100rpx;
}
