.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 28rpx 24rpx 44rpx;
  box-sizing: border-box;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 280rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1f5eff;
  opacity: 0.28;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.28; transform: scale(0.82); }
  50% { opacity: 1; transform: scale(1); }
}

.loading-text,
.empty-text {
  margin-top: 22rpx;
  font-size: 28rpx;
  color: #7a7f87;
  text-align: center;
}

.empty-state {
  padding-top: 280rpx;
}

.business-card,
.action-panel,
.extra-panel {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.05);
}

.business-card {
  overflow: hidden;
}

.card-accent {
  height: 10rpx;
}

.theme-classic { background: linear-gradient(90deg, #1f5eff, #4d8dff); }
.theme-modern { background: linear-gradient(90deg, #475467, #667085); }
.theme-dark { background: linear-gradient(90deg, #161b26, #3a4252); }

.identity-block {
  display: flex;
  gap: 24rpx;
  padding: 26rpx 28rpx 26rpx;
}

.identity-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 24rpx;
  background: #edf0f4;
  flex-shrink: 0;
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1f5eff, #6ca3ff);
  color: #fff;
  font-size: 50rpx;
  font-weight: 700;
}

.identity-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.identity-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.15;
}

.identity-title {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #667085;
}

.identity-company {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #344054;
  line-height: 1.4;
}

.contact-panel {
  margin: 0 28rpx 28rpx;
  border-top: 1rpx solid #edf0f4;
}

.contact-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf0f4;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: #98a2b3;
  margin-bottom: 8rpx;
}

.contact-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
  word-break: break-all;
}

.action-panel {
  margin-top: 20rpx;
  padding: 24rpx;
}

.owner-actions,
.visitor-primary {
  display: flex;
}

.visitor-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.btn-primary,
.btn-secondary,
.btn-light {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 30rpx;
  line-height: normal;
  padding: 0;
  margin: 0;
  border: none;
}

.btn-primary {
  width: 100%;
  height: 92rpx;
  background: #1f5eff;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(31, 94, 255, 0.16);
}

.btn-primary::after,
.btn-light::after {
  border: none;
}

.btn-secondary {
  width: 100%;
  height: 92rpx;
  background: #fff;
  color: #1f2329;
  font-weight: 500;
  border: 1rpx solid #dde2e8;
}

.owner-actions {
  gap: 14rpx;
}

.owner-actions .btn-primary {
  flex: 1.5;
}

.owner-actions .btn-secondary {
  flex: 1;
}

.btn-light {
  flex: 1;
  height: 84rpx;
  background: #f6f7f9;
  color: #344054;
  font-size: 26rpx;
  font-weight: 500;
}

.extra-panel {
  margin-top: 14rpx;
  padding: 24rpx 28rpx;
  opacity: 0.86;
}

.extra-tip {
  font-size: 22rpx;
  color: #98a2b3;
  margin-bottom: 6rpx;
}

.extra-item + .extra-item {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #edf0f4;
}

.extra-label {
  display: block;
  font-size: 22rpx;
  color: #98a2b3;
  margin-bottom: 6rpx;
}

.extra-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #667085;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.36);
  z-index: 100;
}

.exchange-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.24s ease;
  z-index: 101;
}

.exchange-sheet.show {
  transform: translateY(0);
}

.sheet-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.sheet-close {
  font-size: 24rpx;
  color: #667085;
}

.sheet-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: #667085;
  margin-bottom: 22rpx;
}

.exchange-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.exchange-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8f9fb;
}

.exchange-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1f5eff, #6ca3ff);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.exchange-info {
  flex: 1;
  min-width: 0;
}

.exchange-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
}

.exchange-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #667085;
}

.exchange-action {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f5eff;
}
