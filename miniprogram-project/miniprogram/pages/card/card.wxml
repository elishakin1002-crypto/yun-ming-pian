<view class="page">
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="loading-dot"></view>
    <text class="loading-text">名片加载中...</text>
  </view>

  <view wx:elif="{{!enterprise}}" class="empty-state">
    <text class="empty-text">未找到该名片</text>
  </view>

  <view wx:else class="content">
    <view class="business-card">
      <view class="card-accent theme-{{enterprise.cardStyle || 'classic'}}"></view>

      <view class="identity-block">
        <image wx:if="{{enterprise.logoUrl}}" src="{{enterprise.logoUrl}}" class="identity-avatar" mode="aspectFill" />
        <view wx:else class="identity-avatar default-avatar">
          <text>{{enterprise.contactName ? enterprise.contactName[0] : '?'}}</text>
        </view>
        <view class="identity-main">
          <text class="identity-name">{{enterprise.contactName}}</text>
          <text wx:if="{{enterprise.title}}" class="identity-title">{{enterprise.title}}</text>
          <text class="identity-company">{{enterprise.companyName || '未填写公司'}}</text>
        </view>
      </view>

      <view class="contact-panel">
        <view class="contact-item" bindtap="callPhone">
          <text class="contact-label">电话</text>
          <text class="contact-value">{{enterprise.phone || '未填写'}}</text>
        </view>
        <view class="contact-item" bindtap="copyWechat">
          <text class="contact-label">微信</text>
          <text class="contact-value">{{enterprise.wechat || '点击复制'}}</text>
        </view>
      </view>
    </view>

    <view class="action-panel">
      <view class="visitor-primary">
        <view class="btn-primary" bindtap="saveToWallet">
          <text>{{isSaved ? '已保存名片' : '保存名片'}}</text>
        </view>
      </view>
      <view class="visitor-actions">
        <view class="btn-light" bindtap="callPhone">拨打电话</view>
        <button class="btn-light" open-type="share">分享</button>
        <view class="btn-light" bindtap="showLeadForm">交换联系方式</view>
      </view>
    </view>

    <view wx:if="{{enterprise.bio || enterprise.servicesText || enterprise.slogan || enterprise.industry}}" class="extra-panel">
      <view class="extra-tip">更多信息（选看）</view>
      <view wx:if="{{enterprise.industry}}" class="extra-item">
        <text class="extra-label">行业</text>
        <text class="extra-text">{{enterprise.industry}}</text>
      </view>
      <view wx:if="{{enterprise.bio}}" class="extra-item">
        <text class="extra-label">补充说明</text>
        <text class="extra-text">{{enterprise.bio}}</text>
      </view>
      <view wx:if="{{enterprise.servicesText}}" class="extra-item">
        <text class="extra-label">主营方向</text>
        <text class="extra-text">{{enterprise.servicesText}}</text>
      </view>
      <view wx:if="{{enterprise.slogan}}" class="extra-item">
        <text class="extra-label">一句话介绍</text>
        <text class="extra-text">{{enterprise.slogan}}</text>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showExchange}}" class="mask" bindtap="hideExchange"></view>
<view class="exchange-sheet {{showExchange ? 'show' : ''}}">
  <view class="sheet-head">
    <text class="sheet-title">交换联系方式</text>
    <text class="sheet-close" bindtap="hideExchange">关闭</text>
  </view>
  <text class="sheet-desc">选择你的一张名片与{{enterprise.contactName || '对方'}}交换，双方都会保存对方联系方式。</text>

  <view class="exchange-list">
    <view
      wx:for="{{myCards}}"
      wx:key="_id"
      class="exchange-item"
      bindtap="doExchange"
      data-index="{{index}}"
    >
      <view class="exchange-avatar">
        <text>{{item.contactName ? item.contactName[0] : '?'}}</text>
      </view>
      <view class="exchange-info">
        <text class="exchange-name">{{item.cardName || item.contactName || '我的名片'}}</text>
        <text class="exchange-desc">{{item.contactName}} · {{item.companyName || '未填写公司'}}</text>
      </view>
      <text class="exchange-action">交换</text>
    </view>
  </view>
</view>
