.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.preview-card,
.form-card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.05);
}

.preview-card {
  overflow: hidden;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 100%;
  background: #edf0f4;
}

.form-card {
  padding: 28rpx 24rpx 8rpx;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}

.form-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #6d7480;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f4;
}

.field:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #98a2b3;
  margin-bottom: 10rpx;
}

.input,
.textarea {
  width: 100%;
  font-size: 30rpx;
  color: #1f2329;
  box-sizing: border-box;
}

.textarea {
  min-height: 140rpx;
  line-height: 1.65;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #1f5eff;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin-top: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 94, 255, 0.16);
}

.save-btn::after {
  border: none;
}
