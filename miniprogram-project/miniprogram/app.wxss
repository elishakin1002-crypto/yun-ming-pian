/* =============================================
   全局设计系统 — 统一令牌 & 通用类
   ============================================= */

/* --- 页面基底 --- */
page {
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC',
               'Helvetica Neue', Helvetica, 'Segoe UI', Arial, Roboto, sans-serif;
  color: #1d1d1f;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* --- 布局容器 --- */
.container {
  padding: 32rpx;
  box-sizing: border-box;
  width: 100%;
  min-height: 100vh;
}
.container-tab {
  padding: 32rpx 32rpx 160rpx;  /* 底部留 tabBar 空间 */
  box-sizing: border-box;
  width: 100%;
  min-height: 100vh;
}

/* --- 卡片 --- */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.card-compact {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.04);
}

/* --- 排版 --- */
.title-lg {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
  line-height: 1.3;
}
.title-md {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  line-height: 1.4;
}
.title-sm {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.body {
  font-size: 28rpx;
  color: #1d1d1f;
  line-height: 1.6;
}
.caption {
  font-size: 24rpx;
  color: #86868b;
  line-height: 1.5;
}
.label {
  font-size: 22rpx;
  color: #86868b;
  letter-spacing: 0.5rpx;
}

/* --- 按钮 --- */
.btn-primary {
  background: #0066FF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  border: none;
  width: 100%;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.85; }

.btn-secondary {
  background: #E8F0FE;
  color: #0066FF;
  font-size: 28rpx;
  font-weight: 600;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  border: none;
  width: 100%;
}
.btn-secondary::after { border: none; }
.btn-secondary:active { background: #d4e4fd; }

.btn-ghost {
  background: transparent;
  color: #0066FF;
  font-size: 28rpx;
  font-weight: 500;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 2rpx solid #0066FF;
  width: 100%;
}
.btn-ghost::after { border: none; }

/* --- 头像占位 --- */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #E8F0FE;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}
.avatar image {
  width: 100%;
  height: 100%;
}
.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #0066FF;
}

/* --- 加载状态 --- */
.loading-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}
.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #0066FF;
  border-radius: 50%;
  animation: pulse 1.2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.5); opacity: 1; }
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #E8F0FE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 48rpx;
  text-align: center;
  padding: 0 64rpx;
}

/* --- 分割线 --- */
.divider {
  height: 1rpx;
  background: #e5e5e7;
  margin: 24rpx 0;
}

/* --- 安全底部 --- */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
