<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <!-- SVG-style icon using CSS -->
    <view class="tab-icon-wrap">
      <view class="tab-icon tab-icon-{{item.icon}} {{selected === index ? 'tab-icon-selected' : ''}}"></view>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
