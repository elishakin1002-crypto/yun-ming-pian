.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 12rpx;
  color: #86868b;
  transition: color 0.2s ease;
}

.tab-item.active {
  color: #0066FF;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

/* Card icon - using CSS shapes */
.tab-icon-card {
  width: 40rpx;
  height: 28rpx;
  border: 4rpx solid #86868b;
  border-radius: 6rpx;
  position: relative;
}
.tab-icon-card::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #86868b;
}
.tab-icon-card.tab-icon-selected {
  border-color: #0066FF;
}
.tab-icon-card.tab-icon-selected::after {
  background: #0066FF;
}

/* Wallet icon */
.tab-icon-wallet {
  width: 38rpx;
  height: 30rpx;
  border: 4rpx solid #86868b;
  border-radius: 8rpx;
  position: relative;
}
.tab-icon-wallet::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 4rpx;
  right: 4rpx;
  height: 8rpx;
  border: 4rpx solid #86868b;
  border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
}
.tab-icon-wallet.tab-icon-selected {
  border-color: #0066FF;
}
.tab-icon-wallet.tab-icon-selected::before {
  border-color: #0066FF;
}

.tab-text {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}
